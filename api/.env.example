# Postgres connection (local docker-compose default below)
DATABASE_URL="postgresql://zaina:zaina@localhost:5432/zaina?schema=public"

# Firebase Admin SDK (download a service account JSON, base64-encode it,
# or point FIREBASE_SERVICE_ACCOUNT_PATH at the file directly)
FIREBASE_PROJECT_ID=""
FIREBASE_SERVICE_ACCOUNT_PATH=""

# Google Cloud Storage bucket for ID images (private bucket)
GCS_BUCKET_ID_IMAGES=""

# Server
PORT="3000"
NODE_ENV="development"
